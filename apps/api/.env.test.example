# Test Environment Configuration
# This file is used for running tests in an isolated environment

# Database - Test database (different from production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/fz99_lounge_test?schema=public&connection_limit=5"

# Redis - Test Redis instance (different port)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=test-only-not-a-secret
JWT_EXPIRES_IN=90d

# Discord OAuth (Mock values for testing)
DISCORD_CLIENT_ID=test_discord_client_id
DISCORD_CLIENT_SECRET=test-only-not-a-secret
DISCORD_CALLBACK_URL=http://localhost:3001/api/auth/discord/callback

# Application
PORT=3001
NODE_ENV=test

# Web Push (Mock values for testing)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=test@example.com

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=error

# Rate Limiting (disabled for tests)
RATE_LIMIT_ENABLED=false
# Bull queue - test Redis (compose.test.yaml)
REDIS_URL=redis://localhost:6380

# Discord bot must never fire in tests
DISCORD_BOT_ENABLED=false
